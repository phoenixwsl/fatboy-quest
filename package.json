{
  "name": "fatboy-quest",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "肥仔大闯关 - 太空主题作业管理 PWA",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d dist",
    "setup-hooks": "git config core.hooksPath .githooks && echo '✓ pre-commit hook installed'",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "verify": "npx tsc -b && npx vitest run && npx vite build --outDir /tmp/fatboy-verify --emptyOutDir && rm -rf /tmp/fatboy-verify"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "framer-motion": "^11.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.15.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.0.0",
    "gh-pages": "^6.1.1",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.0.5"
  }
}
