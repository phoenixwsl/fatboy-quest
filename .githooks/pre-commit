#!/usr/bin/env bash
# pre-commit 钩子：每次 git commit 前自动验证
#   1. TypeScript 类型检查
#   2. Vitest 单元测试
#   3. Vite 构建
# 任一失败则阻止本次提交。
# 紧急情况下可用 `git commit --no-verify` 跳过（不推荐）

set -e

GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo -e "${YELLOW}[pre-commit]${NC} 验证开始 ..."

# 跳过 only-docs 类型的提交（仅 .md / README 改动时不跑 build，加快迭代）
CHANGED=$(git diff --cached --name-only --diff-filter=ACMR)
HAS_CODE=$(echo "$CHANGED" | grep -E '\.(ts|tsx|js|jsx|css|html|json)$' || true)
if [ -z "$HAS_CODE" ] && [ -n "$CHANGED" ]; then
  echo -e "${YELLOW}[pre-commit]${NC} 仅文档改动，跳过验证"
  exit 0
fi

# 1. TypeScript
echo -e "${YELLOW}[pre-commit]${NC} (1/3) TypeScript 类型检查 ..."
if ! npx tsc -b; then
  echo -e "${RED}[pre-commit] ✗ TypeScript 错误，提交已阻止${NC}"
  echo -e "${RED}修复后再 commit；如确认要绕过：git commit --no-verify${NC}"
  exit 1
fi

# 2. Tests
echo -e "${YELLOW}[pre-commit]${NC} (2/3) Vitest 单元测试 ..."
if ! npx vitest run --reporter=dot; then
  echo -e "${RED}[pre-commit] ✗ 测试失败，提交已阻止${NC}"
  exit 1
fi

# 3. Build (用 /tmp 做输出目录，构建产物不留在仓库里)
echo -e "${YELLOW}[pre-commit]${NC} (3/3) Vite 构建 ..."
BUILD_OUT="/tmp/fatboy-precommit-build-$$"
if ! npx vite build --outDir "$BUILD_OUT" --emptyOutDir > /tmp/fatboy-build.log 2>&1; then
  echo -e "${RED}[pre-commit] ✗ 构建失败，提交已阻止。详细日志：/tmp/fatboy-build.log${NC}"
  tail -20 /tmp/fatboy-build.log
  rm -rf "$BUILD_OUT" 2>/dev/null
  exit 1
fi
rm -rf "$BUILD_OUT" 2>/dev/null

echo -e "${GREEN}[pre-commit] ✓ 全部通过，继续提交${NC}"
